# =============================================
# ReAmped Mobile — Environment Variables
# Copy this file to .env and fill in your values
# Never commit .env to version control!
# =============================================

# ---- API ----
# Base URL of the ReAmped backend API
EXPO_PUBLIC_API_URL=http://localhost:3001

# ---- Expo / EAS ----
# Your Expo account slug (found in app.json)
EXPO_ACCOUNT_SLUG=your-expo-username

# ---- iOS Push Notifications (APNs) ----
# Used by eas notifications:configure
EXPO_APPLE_TEAM_ID=XXXXXXXXXX

# ---- Android Push Notifications (FCM) ----
# Firebase project number (from google-services.json)
EXPO_FIREBASE_SENDER_ID=000000000000

# ---- Sentry (optional crash reporting) ----
SENTRY_DSN=https://xxx@oXXX.ingest.sentry.io/yyy
SENTRY_AUTH_TOKEN=

# ---- Deep linking ----
# URL scheme for the app (defined in app.json scheme field)
APP_SCHEME=reamped

# ---- Feature flags ----
EXPO_PUBLIC_ENABLE_PRO_UPSELL=true
EXPO_PUBLIC_ENABLE_WATCHLIST=true
