—

PORT=3001
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgres://reamped:password@localhost:5432/reamped_db

# JWT — generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_64_byte_random_hex

# Reverb API — https://reverb.com/page/api
REVERB_API_TOKEN=your_reverb_token

# eBay Developer — https://developer.ebay.com
EBAY_APP_ID=your_ebay_app_id
EBAY_OAUTH_TOKEN=your_ebay_oauth_token

# Stripe — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_PRO_MONTHLY_PRICE_ID=price_replace_me
STRIPE_PRO_ANNUAL_PRICE_ID=price_replace_me

# Redis
REDIS_URL=redis://localhost:6379

# CORS (comma-separated origins)
ALLOWED_ORIGINS=http://localhost:3000
