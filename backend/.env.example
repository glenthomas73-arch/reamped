PORT=3001
NODE_ENV=development

# App public URL (used in email links and Stripe redirect URLs)
APP_URL=http://localhost:3000

# PostgreSQL
DATABASE_URL=postgres://reamped:password@localhost:5432/reamped_db

# JWT — generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_64_byte_random_hex

# Reverb API — https://reverb.com/page/api
REVERB_API_TOKEN=your_reverb_token

# eBay Developer — https://developer.ebay.com
# Get App ID and Cert ID from: developer.ebay.com > My Account > Application Keys > Sandbox
EBAY_APP_ID=your_ebay_app_id
EBAY_CERT_ID=your_ebay_cert_id
# Set to 'sandbox' (default) until eBay approves production access, then change to 'production'
EBAY_ENV=sandbox
# eBay Partner Network Campaign ID (for affiliate links) — https://partnernetwork.ebay.com
EBAY_CAMPAIGN_ID=your_ebay_campaign_id

# Guitar Center Affiliate ID — https://www.guitarcenter.com/affiliates
GC_AFFILIATE_ID=your_gc_affiliate_id

# Sweetwater Affiliate ID — https://www.sweetwater.com/about/affiliates/
SW_AFFILIATE_ID=your_sw_affiliate_id

# Stripe — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
# Create prices in Stripe Dashboard > Products > Add product
STRIPE_PRO_MONTHLY_PRICE_ID=price_replace_monthly
STRIPE_PRO_ANNUAL_PRICE_ID=price_replace_annual

# Email (SMTP) — for price alert notifications
# Leave SMTP_HOST unset to use Ethereal test account in development (logs preview URLs)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=alerts@reamped.app

# Redis
REDIS_URL=redis://localhost:6379

# CORS (comma-separated origins)
ALLOWED_ORIGINS=http://localhost:3000
