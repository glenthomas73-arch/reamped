{
      "name": "reamped-backend",
      "version": "1.0.0",
      "description": "ReAmped backend API and aggregation workers",
      "main": "src/server.js",
      "scripts": {
              "start": "node src/server.js",
              "dev": "nodemon src/server.js",
              "worker:reverb": "node src/workers/reverbFetcher.js",
              "worker:ebay": "node src/workers/ebayFetcher.js",
              "worker:gc": "node -e \"require('./src/workers/gcUsedFetcher').runGcUsedFetcher()\"",
              "worker:sweetwater": "node -e \"require('./src/workers/sweetwaterFetcher').runSweetwaterFetcher()\"",
              "worker:alerts": "node -e \"require('./src/workers/alertsWorker').runAlertsWorker()\"",
              "db:migrate": "node src/db/migrate.js",
              "test": "jest"
      },
      "dependencies": {
              "axios": "^1.6.0",
              "bcrypt": "^5.1.1",
              "cors": "^2.8.5",
              "dotenv": "^16.3.1",
              "express": "^4.18.2",
              "express-rate-limit": "^7.1.5",
              "helmet": "^7.1.0",
              "ioredis": "^5.3.2",
              "jsonwebtoken": "^9.0.2",
              "node-cron": "^3.0.3",
              "nodemailer": "^6.9.8",
              "pg": "^8.11.3",
              "stripe": "^14.5.0",
              "uuid": "^9.0.0",
              "winston": "^3.11.0"
      },
      "devDependencies": {
              "jest": "^29.7.0",
              "nodemon": "^3.0.2",
              "supertest": "^6.3.3"
      },
      "engines": {
              "node": ">=18.0.0"
      }
}
